# terraform.tfvars — copy this file, fill in your values, and apply
# Do NOT commit this file to version control (add it to .gitignore)

aws_region           = "ap-south-1"       # Mumbai
cluster_name         = "k8s-cluster"
environment          = "dev"

master_instance_type = "t3.medium"        # 2 vCPU / 4 GB — minimum for kubeadm
worker_instance_type = "t3.medium"
worker_count         = 2

vpc_cidr             = "10.0.0.0/16"
subnet_cidr          = "10.0.1.0/24"
pod_network_cidr     = "10.244.0.0/16"   # Required by Flannel

# Paste the contents of your ~/.ssh/id_rsa.pub (or id_ed25519.pub) here
public_key_material  = "ssh-rsa AAAA...your-public-key-here..."

# Restrict SSH to your IP only (recommended)
# Find your IP: curl ifconfig.me
admin_cidr           = "0.0.0.0/0"       # Change to "YOUR.IP.ADDRESS/32"
